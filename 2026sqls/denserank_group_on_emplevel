# for emp level ,used DENSE_RANK() again

with cte2 as (select *,
dense_rank() over (partition by dept_name order by salary desc)
as highrank,
dense_rank() over (partition by dept_name order by salary asc)
as lowrank
 from employee3
)
select emp_id, emp_name,dept_name, salary from cte2 
where highrank =1 or lowrank=1;


