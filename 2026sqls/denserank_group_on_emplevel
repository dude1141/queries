with cte24 as (select *,
dense_rank() over (partition by dept_name order by salary desc)
as highrank
 from employee3
)
select emp_id, emp_name,dept_name, salary,
 min(salary) as minsalary, max(salary) as maxsalary 
 from cte24 group by dept_name;

#only dense rank gives your answer but it does not give you employeelevel
